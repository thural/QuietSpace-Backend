# ============================================
# QuietSpace Environment Configuration
# ============================================
# Copy this file: cp .env.example .env
# Edit values for your environment.
#
# Local dev:  SPRING_PROFILES_ACTIVE=dev
#   - Only DB_USER_USERNAME, DB_USER_PASSWORD, ADMIN_PASSWORD, JWT_SECRET_KEY
#     are read. Everything else is overridden by application-dev.yml.
#
# Local prod: SPRING_PROFILES_ACTIVE=prod
#   - All variables are read by application-prod.yml.
#
# VPS prod:   Pipeline generates .env from GitHub Secrets automatically.
# ============================================

# === Database ===
DB_ROOT_PASSWORD=rootpassword
DB_NAME=quietspace
DB_USER_USERNAME=quietspace_user
DB_USER_PASSWORD=userpassword
DB_PORT_NUMBER=3306
DB_HOST_NAME=localhost

# === Spring Application ===
SPRING_PROFILES_ACTIVE=dev
ADMIN_PASSWORD=admin123
JWT_SECRET_KEY="oKg2jRhi4VwqC18cA+Xz3WjsWCS8bkOevJNFgv/tkP3tG3JlPTmcuu3jFU2jUYW6v4lthQ8rX94zkSP6i0sbDQ=="
ACTIVATION_URL=http://localhost:3000/activate
SERVER_PORT_NUMBER=8080

# === Frontend ===
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# === MailDev ===
MAILDEV_HOST=localhost
MAILDEV_PORT=1025

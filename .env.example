# ============================================
# QuietSpace Environment Configuration
# ============================================
# Copy this file: cp .env.example .env
# Edit values for your environment.
#
# Most values now have Spring Boot defaults defined in
# application.yml and application-prod.yml, so only
# truly required values need to be set:
#   - DB_USER_PASSWORD  (no default)
#   - ADMIN_PASSWORD    (no default)
#   - JWT_SECRET_KEY    (no default)
#
# The following have defaults and are optional:
#   DB_USER_USERNAME=quietspace_user
#   DB_NAME=quietspace
#   DB_PORT_NUMBER=3306
#   DB_HOST_NAME=database
#   SERVER_PORT_NUMBER=8080
#   FRONTEND_HOST=localhost
#   FRONTEND_PORT=80
#   MAILDEV_HOST=mailpit
#   MAILDEV_PORT=1025
#   ACTIVATION_URL      (no default — required in CI for activation emails)
#
# === Multi-Host Environments ===
# Staging VPS:  SPRING_PROFILES_ACTIVE=dev,   MAILDEV_HOST=mailpit, uses Mailpit
# Production:   SPRING_PROFILES_ACTIVE=prod,  uses Postmark (no MAILDEV_HOST needed)
# ============================================

# === Required ===
DB_USER_PASSWORD=userpassword
ADMIN_PASSWORD=admin123
JWT_SECRET_KEY="oKg2jRhi4VwqC18cA+Xz3WjsWCS8bkOevJNFgv/tkP3tG3JlPTmcuu3jFU2jUYW6v4lthQ8rX94zkSP6i0sbDQ=="

# === Optional (defaults shown) ===
SPRING_PROFILES_ACTIVE=dev
ACTIVATION_URL=http://localhost:3000/activate
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

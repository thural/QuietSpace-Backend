# ============================================
# QuietSpace Backend Environment
# ============================================
# Copy this file: cp .env.example .env
#
# ============================================
# Profile-specific behaviour:
#   dev        H2 in-memory (no Docker), Mailpit SMTP,  Flyway off
#   staging    Docker MySQL,  Mailpit SMTP,  Flyway on
#   prod       Docker MySQL,  Postmark SMTP, Flyway on
# ============================================

# === Required (no defaults) ===
DB_USER_PASSWORD=changeme
ADMIN_PASSWORD=changeme
JWT_SECRET_KEY="oKg2jRhi4VwqC18cA+Xz3WjsWCS8bkOevJNFgv/tkP3tG3JlPTmcuu3jFU2jUYW6v4lthQ8rX94zkSP6i0sbDQ=="

# === Profile selection ===
# dev profile is active by default (via application.yml).
# Override for staging/prod:
#   SPRING_PROFILES_ACTIVE=staging
#   SPRING_PROFILES_ACTIVE=prod
SPRING_PROFILES_ACTIVE=dev

# === Email (dev profile — uses Mailpit via SMTP) ===
# Running backend outside Docker? Set MAILDEV_HOST=localhost
# Running in Docker Compose? Default (mailpit) resolves via Docker DNS
# MAILDEV_HOST=localhost
# MAILDEV_PORT=1025

# === Activation URL ===
# Dev defaults to http://localhost:3000/activate (override in application-dev.yml)
# CI generates: https://${PUBLIC_DOMAIN}/activate
ACTIVATION_URL=http://localhost:3000/activate
